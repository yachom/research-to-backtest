# OpenDART API 인증키 — https://opendart.fss.or.kr 에서 발급
DART_API_KEY=

# LLM — OpenRouter 무료 모델 사용 (docs/MILESTONES.md D2). Phase C에서만 필요하며
# Phase A·B는 LLM 없이 동작한다. 키 발급: https://openrouter.ai/keys
OPENROUTER_API_KEY=
LLM_MODEL=inclusionai/ling-2.6-flash:free

# KRX 정보데이터시스템 로그인 — https://data.krx.co.kr 무료 회원가입 (docs/MILESTONES.md D1 개정)
# 2025년부터 KRX가 데이터 조회에 로그인을 의무화해 투자자 수급·지수 수집에 필요하다.
# 수정주가 OHLCV는 로그인 없이도 수집된다.
KRX_ID=
KRX_PW=

# (후순위) 한국투자증권 KIS API — MVP는 pykrx 사용으로 불필요 (docs/MILESTONES.md D1)
# KIS_APP_KEY=
# KIS_APP_SECRET=

# (후순위) 토스증권 API 키 : 전략 시행 테스트 시 사용예정
CLIENT_ID=
CLIENT_SECRET=